# Copiá este archivo a .env y completá los valores (no subas .env al repo).

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Remitente verificado en Resend (dominio o onboarding de prueba).
RESEND_FROM="VinyaRoots <onboarding@resend.dev>"

# Opcional: copias BCC adicionales para tu equipo (coma separada). Siempre se envía también BCC a rodrigo@autonovax.com.ar (código en lib/ruleta-premio-service.mjs).
# RULETA_BCC="equipo@tudominio.com"

# Puerto del servidor que sirve la web + API (npm start).
PORT=8787

# Si servís solo la API en otro host y el HTML en otro, listá orígenes permitidos (coma).
# Ej.: CORS_ORIGIN=http://localhost:8787,https://tudominio.com
# Vacío = refleja el Origin del request (útil con mismo servidor).
# CORS_ORIGIN=

# --- Vercel + KV (cupones persistentes; se crean al enlazar Vercel KV al proyecto) ---
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
